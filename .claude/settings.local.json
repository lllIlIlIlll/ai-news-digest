{
  "permissions": {
    "allow": [
      "mcp__zread__read_file",
      "Bash(for:*)",
      "Bash(do:*)",
      "Bash(then:*)",
      "Bash(else echo \"OK \\(deleted\\): $f\")",
      "Bash(fi)",
      "Bash(done)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(bun install:*)",
      "Bash(brew install:*)",
      "Bash(curl:*)",
      "Bash(bash:*)",
      "Bash(bun start)",
      "Bash(bun run:*)",
      "Bash(bun pm ls)",
      "Bash(git add:*)",
      "Bash(git reset:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm test"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Verify that all unit tests pass. Run the test suite and check the results.",
            "timeout": 120
          }
        ]
      }
    ]
  }
}